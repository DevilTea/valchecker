{
	"name": "valchecker-cross-library-benchmarks",
	"private": true,
	"type": "module",
	"packageManager": "pnpm@10.34.4",
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"bench": "node ./src/run.mjs",
		"report": "node ./src/report.mjs",
		"smoke": "node ./src/run.mjs --mode smoke --output ../artifacts/benchmark-smoke/raw.json && node ./src/report.mjs --input ../artifacts/benchmark-smoke/raw.json --markdown ../artifacts/benchmark-smoke/report.md --html ../artifacts/benchmark-smoke/report.html",
		"verify": "node ./src/verify.mjs"
	},
	"dependencies": {
		"valibot": "1.4.2",
		"zod3": "npm:zod@3.25.76",
		"zod4": "npm:zod@4.4.3"
	}
}
