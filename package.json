{
	"name": "monorepo",
	"type": "module",
	"version": "1.0.0-rc.0",
	"private": true,
	"packageManager": "pnpm@10.34.4",
	"description": "A JS / TS value checker.",
	"author": "DevilTea <ch870814@gmail.com>",
	"license": "MIT",
	"homepage": "https://github.com/DevilTea/valchecker#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/DevilTea/valchecker.git"
	},
	"bugs": "https://github.com/DevilTea/valchecker/issues",
	"keywords": [],
	"sideEffects": false,
	"engines": {
		"node": ">=22"
	},
	"scripts": {
		"api:surface": "tsx ./scripts/check-api-surface.ts",
		"api:surface:update": "tsx ./scripts/check-api-surface.ts --write",
		"build": "pnpm -r --filter='./packages/*' build",
		"stub": "pnpm -r --filter='./packages/*' stub",
		"newpkg": "tsx ./scripts/newpkg.ts",
		"publint": "pnpm -r --filter='./packages/*' exec publint",
		"release:prepare": "tsx ./scripts/prepare-release.ts",
		"release:publish": "tsx ./scripts/publish-release.ts",
		"release:readiness": "tsx ./scripts/check-release-readiness.ts",
		"release:validate": "pnpm release:readiness && pnpm build && pnpm api:surface && pnpm publint && pnpm test:package && pnpm lint && pnpm typecheck && pnpm test:coverage && pnpm docs:build",
		"docs:dev": "pnpm -r --filter=./docs run dev",
		"docs:build": "pnpm -r --filter=./docs run build",
		"docs:preview": "pnpm -r --filter=./docs run preview",
		"test": "vitest --run",
		"test:coverage": "tsx ./scripts/run-coverage.ts",
		"test:package": "tsx ./scripts/test-packages.ts",
		"test:watch": "vitest --watch",
		"bench": "vitest bench --run",
		"bench:watch": "vitest bench",
		"lint": "eslint .",
		"lint:fix": "eslint --fix .",
		"typecheck": "pnpm -r typecheck",
		"prepare": "simple-git-hooks"
	},
	"devDependencies": {
		"@clack/prompts": "catalog:",
		"@deviltea/eslint-config": "catalog:",
		"@deviltea/tsconfig": "catalog:",
		"@types/node": "catalog:",
		"@vitest/coverage-v8": "catalog:",
		"bumpp": "catalog:",
		"eslint": "catalog:",
		"lint-staged": "catalog:",
		"pathe": "catalog:",
		"pkg-size": "catalog:",
		"publint": "catalog:",
		"rimraf": "catalog:",
		"simple-git-hooks": "catalog:",
		"tsdown": "catalog:",
		"tsx": "catalog:",
		"typescript": "catalog:",
		"vitest": "catalog:",
		"zx": "catalog:"
	},
	"simple-git-hooks": {
		"pre-commit": "pnpm lint-staged"
	},
	"lint-staged": {
		"*": "eslint --fix"
	},
	"publishConfig": {
		"access": "public"
	}
}
